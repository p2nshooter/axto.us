# Copy to .env.local for local dev. In production these are set as
# Cloudflare Pages secrets / GitHub Actions secrets — never commit real values.

# --- Core ---
APP_URL=http://localhost:3000

# --- Email (Resend) — used for password reset / verification emails ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=AXTO <noreply@axto.us>

# --- PayPal ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# --- Midtrans ---
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# --- Crypto payments (NOWPayments — supports BTC/ETH/BNB/SOL/DOGE/USDT) ---
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# --- Optional premium TTS providers (falls back to free browser Web Speech API if unset) ---
ELEVENLABS_API_KEY=
AZURE_TTS_KEY=
AZURE_TTS_REGION=
